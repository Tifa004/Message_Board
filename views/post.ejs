<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%=title %>
  </title>
  <link rel="stylesheet" href="/styles.css" />
</head>

<body>
  <nav>
    <h1>Message Board</h1>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/post">Post Message</a>
    </div>
  </nav>

  <div class="form-container">
    <h2>New Message</h2>

    <% if (locals.errors) { %>
      <ul style="color: #ff4d4d; list-style: none; padding: 0;">
        <% errors.forEach(error=> { %>
          <li><strong>
              <%= error.msg %>
            </strong></li>
          <% }) %>
      </ul>
      <% } %>

        <form action="/" method="POST">
          <div class="form-group">
            <label for="user">Your Name</label>
            <input type="text" id="user" name="username" required
              value="<%= locals.previousData ? previousData.username : '' %>" />
          </div>
          <div class="form-group">
            <label for="text">Message</label>
            <textarea id="text" name="message"
              required><%= locals.previousData ? previousData.message : '' %></textarea>
          </div>
          <button type="submit">Submit Message</button>
        </form>
  </div>
</body>

</html>